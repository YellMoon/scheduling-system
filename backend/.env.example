# 教务管理系统后端配置模板
# 复制为 .env 后修改

# 服务端口
PORT=3001

# 数据库路径（SQLite文件）
DB_PATH=./data/scheduling.db

# JWT密钥（生产环境务必更换为随机字符串）
JWT_SECRET=your-secret-key-change-in-production

# 微信小程序配置（可选）
WECHAT_APPID=wx0000000000000000
WECHAT_APPSECRET=your-wechat-appsecret

# CORS允许的来源（逗号分隔，* 表示允许所有）
CORS_ORIGIN=*

# 日志级别: debug | info | warn | error
LOG_LEVEL=info
