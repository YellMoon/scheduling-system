# 教务管理系统后端配置模板
# 复制为 .env 后修改

# 服务端口
PORT=3001

# 数据库路径（SQLite文件）
DB_PATH=./data/scheduling.db

# JWT密钥（生产环境务必更换为随机字符串）
JWT_SECRET=your-secret-key-change-in-production

# 微信小程序配置（可选）
WECHAT_APPID=wx0000000000000000
WECHAT_APPSECRET=your-wechat-appsecret

# CORS允许的来源（逗号分隔，* 表示允许所有）
CORS_ORIGIN=*

# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# 本地优先部署：主数据电脑与云中继
GEWU_NODE_ROLE=primary-host
GEWU_DEVICE_ID=desktop_host_001
GEWU_HOST_BASE_URL=http://127.0.0.1:3001
GEWU_CLOUD_BASE_URL=https://your-domain.example.com

# 题库移动硬盘独立存储
QUESTION_BANK_ROOT=E:/GewuQuestionBank
QUESTION_BANK_UPLOAD_DIR=E:/GewuQuestionBank/assets

# 部署 smoke 检查：
# node scripts/check_cloud_relay.js $GEWU_CLOUD_BASE_URL
# 需要阿里云网关服务已运行并可访问。
