APP_ENV=staging
SCHEDULE_ENV=staging
NODE_ENV=production
PORT=3000

DB_PATH=/app/data/scheduling-staging.db
READ_DB_PATH=/app/data/scheduling-staging.db

# Redis配置（连接到同一个Docker Compose网络中的redis容器）
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

# OpenSearch配置（本地Docker容器）
OPENSEARCH_ENDPOINT=http://opensearch:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_QUESTION_INDEX=questions-staging

JWT_SECRET=staging-local-secret
