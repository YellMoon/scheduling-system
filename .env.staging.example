NODE_ENV=staging
PORT=3001
JWT_SECRET=replace-with-staging-secret
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USERNAME=replace-with-opensearch-username
OPENSEARCH_PASSWORD=replace-with-opensearch-password
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=replace-with-redis-password

# Local-first primary host and cloud relay
GEWU_NODE_ROLE=primary-host
GEWU_DEVICE_ID=desktop_host_001
GEWU_HOST_BASE_URL=http://127.0.0.1:3001
GEWU_CLOUD_BASE_URL=https://your-domain.example.com

# Removable-drive question bank storage
QUESTION_BANK_ROOT=E:/GewuQuestionBank
QUESTION_BANK_UPLOAD_DIR=E:/GewuQuestionBank/assets

# Deployment smoke check:
# node scripts/check_cloud_relay.js $GEWU_CLOUD_BASE_URL
# Requires the cloud gateway service to be running and reachable.
